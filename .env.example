# App — dedicated port 8787 (avoids 3000–3003 used by other Next.js projects)
PORT=8787

# Google Sign-In — required for pr.finalrev.com (@finalrev.com only).
# Run once: bash scripts/setup-google-oauth.sh
# AUTH_SECRET=openssl rand -base64 32
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# AUTH_ALLOWED_DOMAINS=finalrev.com

# Network-only when auth is NOT configured (LAN / office Wi‑Fi self-host)
# On Vercel, auth protects the app — NETWORK_ONLY is ignored there.
NETWORK_ONLY=true
# ALLOW_PUBLIC_ACCESS=true   # emergency only — opens the app to the internet
# NETWORK_ONLY=false         # same as ALLOW_PUBLIC_ACCESS

# Optional pinned public URL (emails, OAuth redirects, Open Graph)
APP_PUBLIC_URL=https://pr.finalrev.com

# Turso — shared DB when multiple machines need the same data (optional for single Mac + file DB)
# Run: bash scripts/setup-turso.sh
# TURSO_DATABASE_URL=libsql://...
# TURSO_AUTH_TOKEN=...

# Content P&L estimates (optional — defaults shown)
# CONTENT_PNL_QUOTE_VALUE=2500
# CONTENT_PNL_PRO_ANNUAL_VALUE=348

# GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# Shorts editor: uses Gemini + bundled ffmpeg (npm run team:serve for export)

# PostHog — Tooltrace designer funnel lives in project 167207 (not 209711 FinalRev)
POSTHOG_PERSONAL_API_KEY=phx_your_key_here
POSTHOG_TOOLTRACE_PROJECT_ID=167207
POSTHOG_PROJECT_ID=209711
POSTHOG_HOST=https://us.posthog.com
POSTHOG_TOOLTRACE_HOSTNAMES=tooltrace.ai,www.tooltrace.ai,staging.tooltrace.ai
POSTHOG_FINALREV_HOSTNAMES=finalrev.com,www.finalrev.com,staging.finalrev.com

# Stripe — Tooltrace Pro subscriptions
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_ENV_NAME=production

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Metricool — optional API sync (PDF import still works)
METRICOOL_USER_TOKEN=your_token_here
METRICOOL_USER_ID=your_user_id
METRICOOL_BLOG_ID=your_blog_id
METRICOOL_TIMEZONE=America/Los_Angeles

# Resend — Monday PR weekly brief email
# RESEND_API_KEY=re_...
# WEEKLY_BRIEF_FROM=finalREV PR <notifications@gofinalrev.com>
# WEEKLY_BRIEF_TO=vladimir@finalrev.com,julian@finalrev.com
# WEEKLY_BRIEF_CC=david@finalrev.com,devon@finalrev.com

# Slack — optional digest on PDF import
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Local Monday cron — scripts/local-weekly-sync.sh (host Mac, not Vercel)
# CRON_SECRET=generate-a-random-string
