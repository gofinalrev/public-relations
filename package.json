{
  "name": "finalrev-pr-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/print-lan-url.js && next dev --hostname 0.0.0.0 -p 8787",
    "dev:clean": "rm -rf .next && node scripts/print-lan-url.js && next dev --hostname 0.0.0.0 -p 8787",
    "dev:lan": "npm run dev",
    "build": "next build",
    "start": "node scripts/print-lan-url.js && next start --hostname 0.0.0.0 -p 8787",
    "start:lan": "npm run start",
    "team:serve": "npm run build && npm run start",
    "cron:weekly": "bash scripts/local-weekly-sync.sh",
    "deploy": "bash scripts/deploy-vercel.sh",
    "sync-env": "bash scripts/sync-vercel-env.sh",
    "setup:auth": "bash scripts/setup-auth.sh",
    "import-pdf": "tsx --env-file=.env.local scripts/import-metricool-pdf.ts",
    "lint": "eslint"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.2",
    "@libsql/client": "^0.15.15",
    "@napi-rs/canvas": "^1.0.1",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.75.1",
    "ai": "^7.0.6",
    "apexcharts": "^5.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "link-preview-js": "^4.0.4",
    "lucide-react": "^1.22.0",
    "next": "15.5.19",
    "pdf-parse": "^2.4.5",
    "react": "19.1.0",
    "react-apexcharts": "^2.1.1",
    "react-dom": "19.1.0",
    "resend": "^4.8.0",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "twitter-text": "^3.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/twitter-text": "^3.1.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
